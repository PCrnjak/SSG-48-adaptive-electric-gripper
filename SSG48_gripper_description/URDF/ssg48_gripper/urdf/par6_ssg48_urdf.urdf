<?xml version="1.0" encoding="utf-8"?>
<!-- SSG48 Gripper only  PAR6 robot arm links removed -->
<robot
  name="ssg48_gripper">
  <link
    name="gripper">
    <inertial>
      <origin
        xyz="-6.7987E-05 0.0001694 -0.077391"
        rpy="0 0 0" />
      <mass
        value="0.374" />
      <inertia
        ixx="0.00012751"
        ixy="-1.7736E-07"
        ixz="-2.8206E-06"
        iyy="5.8635E-05"
        iyz="-5.29E-07"
        izz="0.00014769" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://ssg48_gripper/meshes/gripper.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://ssg48_gripper/meshes/gripper.STL" />
      </geometry>
    </collision>
  </link>
  <link
    name="jaw1">
    <inertial>
      <origin
        xyz="0.0033269 0.029197 -0.0097237"
        rpy="0 0 0" />
      <mass
        value="0.02" />
      <inertia
        ixx="3.7875E-06"
        ixy="6.5971E-07"
        ixz="3.113E-07"
        iyy="1.5397E-06"
        iyz="-6.1777E-07"
        izz="4.4716E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://ssg48_gripper/meshes/jaw1.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.29804 0.29804 0.29804 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://ssg48_gripper/meshes/jaw1.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="jaw1_JOINT"
    type="prismatic">
    <origin
      xyz="0 0 -0.11745"
      rpy="-3.1416 0 -3.1416" />
    <parent
      link="gripper" />
    <child
      link="jaw1" />
    <axis
      xyz="0 -1 0" />
    <limit
      lower="-0.024"
      upper="0"
      effort="20"
      velocity="0.1" />
  </joint>
  <link
    name="jaw2">
    <inertial>
      <origin
        xyz="-0.0033269 -0.029197 -0.0097237"
        rpy="0 0 0" />
      <mass
        value="0.02" />
      <inertia
        ixx="3.7875E-06"
        ixy="6.5971E-07"
        ixz="-3.113E-07"
        iyy="1.5397E-06"
        iyz="6.1777E-07"
        izz="4.4716E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://ssg48_gripper/meshes/jaw2.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.29804 0.29804 0.29804 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://ssg48_gripper/meshes/jaw2.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="jaw2_JOINT" type="prismatic">
    <mimic joint="jaw1_JOINT" multiplier="-1" offset="0"/>
    <origin
      xyz="0 0 -0.11745"
      rpy="-3.1416 0 -3.1416" />
    <parent
      link="gripper" />
    <child
      link="jaw2" />
    <axis
      xyz="0 -1 0" />
    <limit
      lower="0"
      upper="0.024"
      effort="20"
      velocity="0.1" />
  </joint>

  <link name="tcp">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.003"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="tcp_fixed_joint" type="fixed">
    <parent link="gripper"/>
    <child link="tcp"/>
    <origin xyz="0 0 -0.16" rpy="0 0 0"/>
  </joint>

  <transmission name="jaw_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="jaw1_JOINT">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="jaw_motor">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

</robot>
