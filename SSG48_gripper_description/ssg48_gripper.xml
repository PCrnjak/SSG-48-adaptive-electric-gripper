<mujoco model="ssg48_gripper">
  <compiler angle="radian" autolimits="true" meshdir="assets"/>

  <option integrator="implicitfast"/>

  <!-- Default -->
  <default>
    <default class="SSG48_gripper">
      <joint armature="0.01" damping="0.2" frictionloss="0"/>
      <position forcerange="-50 50" ctrlrange="-0.0235 0" kp="1000"/>
    </default>
  </default>

  <asset>
    <mesh name="gripper" file="gripper_SSG48.STL" scale="1 1 1"/>
    <mesh name="jaw1" file="jaw1_SSG48.STL" scale="1 1 1"/>
    <mesh name="jaw2" file="jaw2_SSG48.STL" scale="1 1 1"/>
  </asset>

  <worldbody>
    <body name="gripper">
      <inertial pos="-6.7987e-05 0.0001694 -0.077391" quat="0.464161 0.46546 -0.535128 0.530603" mass="0.374" diaginertia="0.00014808 0.000127124 5.86313e-05"/>
      <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="gripper"/>

      <!-- Camera center -->
      <body name="camera_center" pos="0.0 -0.09 0.1">
        <geom size="0.005 0.005 0.005" pos="0. 0. 0."
            contype="0" conaffinity="0"
            type="box" rgba="1.00 0.00 0.0 0" />
        <camera name="egocentric" pos="0 0 0" xyaxes="-1 0 0 0 0 1" fovy="90" />
      </body>

      <body name="tcp_link" pos="0 -0.22 0">
        <site name="tcp"
              pos="0 0 0"
              size="0.005"
              rgba="1 0 0 0"/>
        <geom type="capsule" fromto="0 0 -0.5 0 0 0.5" size="0.01" rgba="1.0 0.2 0.2 0.0" contype="0" conaffinity="0"/>
      </body>

      <body name="jaw1" pos="0 0 -0.11745" quat="1.34924e-11 3.67321e-06 1 3.67321e-06">
        <inertial pos="0.0033269 0.029197 -0.0097237" quat="0.427918 0.661892 -0.405093 0.463342" mass="0.02" diaginertia="4.64011e-06 3.93984e-06 1.21885e-06"/>
        <joint name="jaw1_JOINT" pos="0 0 0" axis="0 -1 0" type="slide" range="-0.0235 0" class="SSG48_gripper"/>
        <geom type="mesh"
              mesh="jaw1"
              rgba="0.29804 0.29804 0.29804 1"
              friction="1.2 0.3 0.001"
              solref="0.002 1"
              solimp="0.9 0.95 0.001"/>
      </body>

      <body name="jaw2" pos="0 0 -0.11745" quat="1.34924e-11 3.67321e-06 1 3.67321e-06">
        <inertial pos="-0.0033269 -0.029197 -0.0097237" quat="0.405093 0.463342 -0.427918 0.661892" mass="0.02" diaginertia="4.64011e-06 3.93984e-06 1.21885e-06"/>
        <joint name="jaw2_JOINT" pos="0 0 0" axis="0 -1 0" type="slide" range="0 0.0235" class="SSG48_gripper"/>
        <geom type="mesh"
              mesh="jaw2"
              rgba="0.29804 0.29804 0.29804 1"
              friction="1.2 0.3 0.001"
              solref="0.002 1"
              solimp="0.9 0.95 0.001"/>
      </body>

    </body>
  </worldbody>

  <!-- Gripper fingers are parallel -->
  <equality>
    <joint joint1="jaw2_JOINT" joint2="jaw1_JOINT" polycoef="0 -1 0 0 0"/>
  </equality>

  <!-- Define actuators -->
  <actuator>
    <position name="actuator_jaw" joint="jaw1_JOINT" class="SSG48_gripper"/>
  </actuator>

</mujoco>
